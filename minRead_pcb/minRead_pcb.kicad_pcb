	(gr_text_box "Welcome to de-link, the open-source ESP32 reading/devkit platform. \n\nThe majority of the components will be on the back of this device, while only the bottom four buttons below will sit on this side. \n\nThis board mainly supports the GDEQ426T82 display variant, but it can be re-purpose for most other GoodDisplay/Waveshare branded SPI e-paper displays. The buttons can be manually placed elsewhere by using either TP1-TP4 (for the bottom row), or the marked positions of the side-buttons. The other side of these normally-open switches is ground, with the exception being the power button which is normally open between GPIO and 3v3. \n\nYou may also access the header of LED pins, unused GPIO, and GND/3v3 via 10-pin accessory connected on the bottom right of the other side."
		(start 107.75 62)
		(end 169.75 89)
		(margins 1.0025 1.0025 1.0025 1.0025)
		(angle 180)
		(layer "F.SilkS")
		(uuid "2d362b9a-efbd-4666-bbb6-a5d15efd9713")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
			(justify left top)
		)
		(border yes)
		(stroke
			(width 0.1)
			(type dash)
		)
	)
	(gr_text_box "LED+ |  G\nW-   |  C-\n46   |  45\n47   |  15\n3V3  |  16"
		(start 157.5 43.5)
		(end 166.5 56.25)
		(margins 1.0025 1.0025 1.0025 1.0025)
		(angle 180)
		(layer "F.SilkS")
		(uuid "e42efeab-9b6a-4337-93a7-72a6b442ce7c")
